<?xml version='1.0' encoding='utf-8'?>
<interface version="1.5">
  <object class="ttk.Frame" id="sales_root" named="True">

    <layout manager="pack">
      <property name="expand">true</property>
      <property name="fill">both</property>
    </layout>

    <!-- Main container: left toolbar + right content -->
    <child>
      <object class="ttk.Frame" id="main_frame" named="True">
        <layout manager="pack">
          <property name="expand">true</property>
          <property name="fill">both</property>
        </layout>

        <!-- LEFT: toolbar -->
        <child>
          <object class="ttk.Frame" id="toolbar_frame" named="True">
            <layout manager="pack">
              <property name="side">left</property>
              <property name="fill">y</property>
              <property name="padx">6</property>
              <property name="pady">6</property>
            </layout>

            <child>
              <object class="ttk.Button" id="btn_new_sale" named="True">
                <property name="text">Новий продаж</property>
                <layout manager="pack">
                  <property name="fill">x</property>
                  <property name="pady">4</property>
                </layout>
              </object>
            </child>

            <child>
              <object class="ttk.Button" id="btn_refresh" named="True">
                <property name="text">Оновити</property>
                <layout manager="pack">
                  <property name="fill">x</property>
                  <property name="pady">4</property>
                </layout>
              </object>
            </child>

          </object>
        </child>

        <!-- RIGHT: table -->
        <child>
          <object class="ttk.Frame" id="content_frame" named="True">
            <layout manager="pack">
              <property name="side">left</property>
              <property name="expand">true</property>
              <property name="fill">both</property>
              <property name="padx">6</property>
              <property name="pady">6</property>
            </layout>

            <child>
              <object class="ttk.Treeview" id="tree_sales" named="True">
                <property name="selectmode">browse</property>
                <layout manager="pack">
                  <property name="expand">true</property>
                  <property name="fill">both</property>
                </layout>
              </object>
            </child>

          </object>
        </child>

      </object>
    </child>

  </object>
</interface>